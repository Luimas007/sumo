# =============================================================================
#  traffic.env
#  Human-readable environment config for real-world traffic realism.
#  Every variable here is loaded at runtime by config/env_loader.py.
#  Change a value and re-run the simulation - no --rebuild needed
#  unless you change a geometry or TL variable in simulation_config.py.
#
#  Format:  KEY = VALUE     (no quotes needed for numbers)
#           Lines starting with # are comments
# =============================================================================


# -----------------------------------------------------------------------------
#  RANDOMNESS SEED
#  Controls the random number generator used for speeds, gaps, lane changes.
#  Change this integer to get a completely different but reproducible run.
#  Set to -1 to use a fresh random seed every run (fully unpredictable).
# -----------------------------------------------------------------------------
RANDOM_SEED = 42


# -----------------------------------------------------------------------------
#  SPEED VARIATION
#  Real drivers don't all drive at the speed limit.  Each vehicle gets a
#  personal "desired speed factor" drawn from a normal distribution:
#    mean  = SPEED_FACTOR_MEAN   (1.0 = exactly the speed limit)
#    std   = SPEED_FACTOR_STD    (higher = more variation between drivers)
#  Examples:
#    0.85 mean -> most drivers go 85% of the limit (cautious road)
#    1.05 mean -> most drivers slightly exceed the limit (busy arterial)
#    0.05 std  -> very consistent  |  0.20 std -> wildly varied
#  Clamped to [MIN_SPEED_FACTOR, MAX_SPEED_FACTOR] per vehicle type.
# -----------------------------------------------------------------------------
SPEED_FACTOR_MEAN    = 1.00
SPEED_FACTOR_STD     = 0.12
MIN_SPEED_FACTOR_CAR = 0.70
MAX_SPEED_FACTOR_CAR = 1.30
MIN_SPEED_FACTOR_HGV = 0.65
MAX_SPEED_FACTOR_HGV = 1.05


# -----------------------------------------------------------------------------
#  DRIVER IMPERFECTION (sigma)
#  SUMO's Krauss car-following model uses sigma to model driver imperfection.
#    0.0 = robot driver (perfectly consistent)
#    1.0 = very erratic (random speed fluctuations every step)
#  Each vehicle class gets its own sigma drawn from a range:
#    e.g. car sigma in [CAR_SIGMA_MIN, CAR_SIGMA_MAX]
# -----------------------------------------------------------------------------
CAR_SIGMA_MIN        = 0.20
CAR_SIGMA_MAX        = 0.70
TRUCK_SIGMA_MIN      = 0.10
TRUCK_SIGMA_MAX      = 0.40
BUS_SIGMA_MIN        = 0.05
BUS_SIGMA_MAX        = 0.25
MOTO_SIGMA_MIN       = 0.40
MOTO_SIGMA_MAX       = 0.90


# -----------------------------------------------------------------------------
#  REACTION TIME (tau) - seconds
#  The time a driver takes to react to the vehicle ahead braking.
#  Real values: 0.6s (alert) to 2.5s (distracted/fatigued).
#  Each vehicle gets a value drawn uniformly from [TAU_MIN, TAU_MAX].
# -----------------------------------------------------------------------------
TAU_MIN              = 0.60
TAU_MAX              = 1.80


# -----------------------------------------------------------------------------
#  FOLLOWING DISTANCE (minGap) - metres
#  Minimum bumper-to-bumper gap a driver maintains to the vehicle ahead.
#  Real values: 1.0m (tailgating) to 5.0m (cautious).
# -----------------------------------------------------------------------------
MIN_GAP_MIN          = 1.20
MIN_GAP_MAX          = 4.50


# -----------------------------------------------------------------------------
#  LANE CHANGE BEHAVIOUR
#  Controls how aggressively drivers change lanes.
#
#  LC_STRATEGIC   : willingness to change for a better route (0=never, 1=always)
#  LC_COOPERATIVE : willingness to yield to others wanting to change (0=never, 1=always)
#  LC_SPEED_GAIN  : min relative speed gain needed to trigger an overtake change
#                   (0=change for any gain, 1=only if it doubles speed)
#  LC_KEEP_RIGHT  : desire to return to right lane after overtaking (0=never, 1=always)
#  LC_LOOK_AHEAD  : how many vehicles ahead a driver looks when deciding (1-10)
#  LC_IMPATIENCE  : how quickly driver impatience grows at red lights (0=patient, 1=very)
# -----------------------------------------------------------------------------
LC_STRATEGIC         = 1.00
LC_COOPERATIVE       = 0.80
LC_SPEED_GAIN        = 0.10
LC_KEEP_RIGHT        = 0.80
LC_LOOK_AHEAD        = 3
LC_IMPATIENCE        = 0.30


# -----------------------------------------------------------------------------
#  JUNCTION BEHAVIOUR
#  Controls how drivers behave at the traffic light junction.
#
#  JUNCTION_MODEL_IGNORE_FPS  : probability of ignoring a red (0=never, 0.05=5%)
#                                Models real-world red-light running.
#  JUNCTION_MODEL_SIGMA_MINOR : imperfection when crossing a minor/yield junction
#  ANTICIPATION_DIST          : metres ahead driver starts braking for red light
# -----------------------------------------------------------------------------
JUNCTION_MODEL_IGNORE_FPS = 0.00
JUNCTION_MODEL_SIGMA_MINOR = 0.40
ANTICIPATION_DIST          = 80.0


# -----------------------------------------------------------------------------
#  ACCELERATION / DECELERATION VARIATION
#  Each vehicle's accel and decel are randomised within these fractions
#  of the base value from simulation_config.py.
#  Example: base accel=2.6, variation=0.20 -> actual range [2.08, 3.12]
# -----------------------------------------------------------------------------
ACCEL_VARIATION      = 0.20
DECEL_VARIATION      = 0.15


# -----------------------------------------------------------------------------
#  DEPARTURE RANDOMISATION
#  DEPART_SPEED_VARIATION : extra +-fraction applied to insertion speed.
#                           0.0 = all vehicles insert at desired speed
#                           0.3 = +/-30% variation at insertion
# -----------------------------------------------------------------------------
DEPART_SPEED_VARIATION = 0.20


# -----------------------------------------------------------------------------
#  EMERGENCY VEHICLE REALISM
#  OTHER_DRIVER_YIELD_PROB : probability that a normal vehicle yields (pulls
#    aside) when an ambulance is within YIELD_AWARENESS_DIST metres.
#    0.0 = no one yields (tests pure signal priority)
#    0.9 = most drivers yield (realistic)
#  YIELD_AWARENESS_DIST : metres at which drivers become aware of siren
# -----------------------------------------------------------------------------
OTHER_DRIVER_YIELD_PROB  = 0.75
YIELD_AWARENESS_DIST     = 50.0


# -----------------------------------------------------------------------------
#  TRAFFIC DENSITY PULSE
#  Real traffic has rush-hour peaks.  These settings create a sinusoidal
#  flow multiplier over the simulation:
#    PULSE_ENABLED  : True / False
#    PULSE_PEAK     : multiplier at peak  (e.g. 1.8 = 80% more vehicles)
#    PULSE_TROUGH   : multiplier at trough (e.g. 0.4 = 60% fewer)
#    PULSE_PERIOD   : seconds for one full peak-trough-peak cycle
# -----------------------------------------------------------------------------
PULSE_ENABLED        = False
PULSE_PEAK           = 1.80
PULSE_TROUGH         = 0.40
PULSE_PERIOD         = 120.0
